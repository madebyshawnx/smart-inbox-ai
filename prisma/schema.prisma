// Phase 1: sample-email classification + feedback (no Gmail/auth yet).
// Phase 3 adds PriorityProfile + SmartRule. A single default profile stands in
// for per-user profiles until auth arrives.
// User, ConnectedAccount, WorkMode still come later.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("SMART_INBOX_DATABASE_URL")
}

model EmailMessage {
  id          String   @id @default(cuid())
  sourceId    String   @unique // fixture/sample id, becomes Gmail message id in Phase 2
  threadId    String?
  senderName  String
  senderEmail String
  subject     String
  bodyText    String
  receivedAt  DateTime
  // Gmail labelIds (JSON array) captured at sync — UNREAD/STARRED/IMPORTANT/
  // INBOX etc. The signal behavioral learning reads to infer how the user
  // handles a sender. Null for sample fixtures.
  gmailLabels String?
  createdAt   DateTime @default(now())

  classification EmailClassification?
  feedback       UserFeedback[]
}

model EmailClassification {
  id             String       @id @default(cuid())
  emailMessageId String       @unique
  emailMessage   EmailMessage @relation(fields: [emailMessageId], references: [id])

  priorityLevel       String // high | medium | low | ignore
  urgencyLevel        String // urgent | soon | later | none
  importanceScore     Int
  confidenceScore     Int
  category            String
  subcategory         String?
  summary              String
  whyThisMatters       String
  recommendedNextStep  String
  detectedDeadline     String?
  requiresResponse     Boolean
  requiresDecision     Boolean
  requiresPayment      Boolean
  requiresScheduling   Boolean
  needsFollowUp        Boolean
  waitingOnReply       Boolean
  riskIfIgnored        String?
  suggestedBucket      String
  safeToIgnore         Boolean
  modelVersion         String
  createdAt            DateTime @default(now())
}

model UserFeedback {
  id             String       @id @default(cuid())
  emailMessageId String
  emailMessage   EmailMessage @relation(fields: [emailMessageId], references: [id])
  feedbackType   String // correct | wrong | more_like_this | ... (see master prompt)
  feedbackNotes  String?
  createdAt      DateTime @default(now())
}

model ConnectedAccount {
  id                    String    @id @default(cuid())
  provider              String // "google"
  providerAccountId     String // the connected Gmail address
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  tokenExpiry           DateTime?
  scopes                String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([provider, providerAccountId])
}

model PriorityProfile {
  id        String   @id @default(cuid())
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rules SmartRule[]
}

model SmartRule {
  id                String          @id @default(cuid())
  priorityProfileId String
  priorityProfile   PriorityProfile @relation(fields: [priorityProfileId], references: [id], onDelete: Cascade)
  ruleText          String // plain-English rule, e.g. "Always prioritize emails from my boss"
  isActive          Boolean         @default(true)
  priorityWeight    Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model DismissedSuggestion {
  id        String   @id @default(cuid())
  // Stable signature of a suggested rule (so the same suggestion isn't shown
  // again once the user dismisses it).
  signature String   @unique
  createdAt DateTime @default(now())
}

model DailyEmailBrief {
  id                  String   @id @default(cuid())
  briefingDate        DateTime
  totalEmailsReviewed Int
  needsAttentionCount Int
  followUpCount       Int
  deadlineCount       Int
  moneyOrAccountCount Int
  waitingOnReplyCount Int
  readLaterCount      Int
  lowPriorityCount    Int
  safeToIgnoreCount   Int
  needsReviewCount    Int
  summary             String
  createdAt           DateTime @default(now())
}
