# Copy to .env and fill in real values. Never commit the filled-in file.

# Local SQLite for Phase 1 (sample-email classification, no Gmail yet)
# Use file:./dev.db locally
SMART_INBOX_DATABASE_URL=

# Required for the classification pipeline to call Claude
ANTHROPIC_API_KEY=

# Optional. Claude model used for email classification. Defaults to
# claude-haiku-4-5 (cheap, handles this structured task well). Override only if
# you need a different model, e.g. claude-sonnet-4-6.
CLASSIFICATION_MODEL=

# Google OAuth for Gmail read-only ingestion (Google Cloud Console -> Credentials).
# Redirect URI must match the one registered there exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Encrypts stored Gmail tokens (AES-256-GCM). Generate 32 random bytes, base64:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=
