    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "google-auth-library": "^10.9.0",
    "lucide-react": "^1.22.0",
    "motion": "^12.42.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hotkeys-hook": "^5.3.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
